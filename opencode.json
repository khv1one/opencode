{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "manager",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm *": "deny",
      "rm -rf *": "deny",
      "docker *": "ask",
      "docker-compose *": "ask",
      "docker build *": "ask",
      "docker run *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git reset --hard *": "deny",
      "git clean *": "deny",
      "git branch -D *": "ask",
      "git branch -d *": "ask",
      "git rebase *": "ask",
      "kubectl *": "ask",
      "helm *": "ask",
      "migrate *": "ask",
      "go mod tidy": "ask",
      "go get *": "ask",
      "go install *": "ask",
      "sudo *": "deny",
      "chmod *": "ask",
      "chown *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "ssh *": "deny",
      "scp *": "deny",
      "rsync *": "ask",
      "brew install *": "ask",
      "brew upgrade *": "ask",
      "npm install *": "ask",
      "pip install *": "ask",
      "psql *": "ask",
      "clickhouse-client *": "ask",
      "mkfs *": "deny",
      "fdisk *": "deny",
      "dd *": "ask",
      "reboot": "deny",
      "shutdown": "deny",
      "kill *": "ask",
      "killall *": "ask"
    },
    "doom_loop": "ask",
    "external_directory": "ask"
  }
}
